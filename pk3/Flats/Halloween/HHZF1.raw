ดดทททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททดดดดดททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททดดดดดทททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททดดดดทททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททดดดดดททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททดดดดดทททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททดดดดดดดดดดดดดดดดดดดดททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททดดดดดดดดดดดดดดดดดดดดทททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททดดดดดททททททททททททททฎดดทททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททดดดดดททททททททททททททฎฎดดทททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททดดดดทททททททททททททททฎฎดดททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททดดดดดทททททททททททททททฎฎฎดดททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททดดดดดททททททททททททททททฎฎฎดดททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททดดดดดททททททททททททททททฎฎฎฎดดททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททดดดดททททททททททททททททฎฎฎฎฎดดททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททดดดทททททททททททททททททฎฎฎฎฎดดทททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททดดดททททททททททททททททททฎฎฎฎฎดดททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททดดดทททททททททททททททททททฎฎฎฎฎดดทททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททดดดททททททททททททททททททททฎฎฎฎฎดดททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททดดดทททททททททททททททททททททฎฎฎฎฎดดทททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททดดดททททททททททททททททททททททฎฎฎฎฎดดททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททดดดทททททททททททททททททททททททฎฎฎฎฎดดทททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททดดททททททททททททททททททททททททฎฎฎฎฎดดทททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททดดทททททททททททททททททททททททททฎฎฎฎฎดดทททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททฎฎดดททททททททททททททททททททททททททฎฎฎฎฎดดททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททฎฎฎฎฎดดทททททททททททททททททททททททททททฎฎฎฎฎดดททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททฎฎฎฎฎดดททททททททททททททททททททททททททททฎฎฎฎฎดดททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททฎฎฎฎฎดดทททททททททททททททททททททททททททททฎฎฎฎฎดดททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททฎฎฎฎฎดดททททททททททททททททททททททททททททททฎฎฎฎฎดดททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททฎฎฎฎฎดดทททททททททททททททททททททททททททททททฎฎฎฎฎดดททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททฎฎฎฎฎดดททททททททททททททททททททททททททททททททฎฎฎฎฎดดททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททฎฎฎฎฎดดททททททททททททททททททททททททททททททททฎฎฎฎฎดดททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททฎฎฎฎฎดดททททททททททททททททททททททททททททททททฎฎฎฎฎดดททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททฎฎฎฎฎดดททททททททททททททททททททททททททททททททฎฎฎฎฎดดททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททฎฎฎฎฎดดททททททททททททททททททททททททททททททททฎฎฎฎฎดดททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททฎฎฎฎฎดดททททททททททททททททททททททททททททททททฎฎฎฎฎดดททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททฎฎฎฎฎดดททททททททททททททททททททททททททททททททฎฎฎฎฎดดททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททฎฎฎฎฎดดททททททททททททททททททททททททททททททททฎฎฎฎฎดดททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททฎฎฎฎฎดดททททททททททททททททททททททททททททททททฎฎฎฎฎฎดททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททททฎฎฎฎฎดดททททททททททททททททททททททททททททททททฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎดดททททททททททททททททททททททททททททททททฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎดดททททททททททททททททททททททททททททททททฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎดดททททททททททททททททททททททททททททททททฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎดดททททททททททททททททททททททททททททททททฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎฎดดททททททททททททททททททททททททททททททททฎฎฎฎฎ